<%- layout("./layouts/boilerplate") %>

<section class="form-card">
    <div class="form-header">
        <p class="eyebrow">New Employee</p>
        <h2>Add a New Employee</h2>
    </div>

    <form action="/employees" method="POST" class="employee-form">
        <div class="form-group">
            <label for="empName">Employee Name</label>
            <input type="text" id="empName" name="employee[empName]" placeholder="Enter employee name" required>
        </div>

        <div class="form-group">
            <label for="empDesignation">Designation</label>
            <input type="text" id="empDesignation" name="employee[empDesignation]" placeholder="Enter designation" required>
        </div>

        <div class="form-group">
            <label for="empSalary">Salary</label>
            <input type="number" id="empSalary" name="employee[empSalary]" placeholder="Enter salary" required>
        </div>

        <div class="form-group">
            <label for="empContact">Contact</label>
            <input type="text" id="empContact" name="employee[empContact]" placeholder="Enter contact number" required>
        </div>

        <div class="form-actions">
            <button type="submit" class="action-btn primary">Create Employee</button>
            <a href="/employees" class="action-btn secondary">Cancel</a>
        </div>
    </form>
</section>